# Managed PostgreSQL (Vercel/production compatible)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
AUTH_SECRET="replace-with-a-strong-random-secret"

# Must be true on Vercel production (HTTPS)
AUTH_COOKIE_SECURE="true"

# Razorpay placeholders
RAZORPAY_KEY_ID="rzp_test_placeholder"
RAZORPAY_KEY_SECRET="replace-me"
RAZORPAY_WEBHOOK_SECRET="replace-with-webhook-secret"

# WhatsApp notifications (optional for API send; floating button works regardless)
NEXT_PUBLIC_WHATSAPP_NUMBER="919000000000"
WHATSAPP_ADMIN_PHONE="919000000000"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Public site URL used for canonical metadata/sitemap URLs
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Google Places Autocomplete (Kundli Birth Place)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
